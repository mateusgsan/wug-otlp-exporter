# WhatsUp Gold Configuration
WUG_URL=https://seu-wug-server:9644/api/v1
WUG_USERNAME=seu_usuario
WUG_PASSWORD=sua_senha
VERIFY_SSL=true

# OTLP Configuration
# Para Grafana Cloud
OTLP_ENDPOINT=otlp-gateway-prod-us-central-1.grafana.net:443
OTLP_PROTOCOL=grpc
OTLP_HEADERS=Authorization=Bearer seu_token_grafana

# Para OpenTelemetry Collector local
# OTLP_ENDPOINT=localhost:4317
# OTLP_PROTOCOL=grpc

# Para HTTP
# OTLP_ENDPOINT=http://localhost:4318
# OTLP_PROTOCOL=http

# Service Configuration
SERVICE_NAME=whatsup-gold
SCRAPE_INTERVAL=60
